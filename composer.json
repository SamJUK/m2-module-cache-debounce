    "require": {
        "php": "^7.0|^8.0"
    },
    "license": [
        "MIT"
    ],
    "autoload": {
        "files": [
            "registration.php"
        ],
        "psr-4": {
            "SamJUK\\CacheDebounce\\": ""
        }
    },
